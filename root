function classNames(...classes) {
  return classes.filter(Boolean).join(" ");
}

function downloadJson(data) {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "tour-de-france-2026-voorspellingen.json";
  a.click();
  URL.revokeObjectURL(url);
}

export default function TourPredictionApp() {
  const [stages, setStages] = useState(() => {
    try {
      const saved = localStorage.getItem("tdf2026StagesJson");
      return saved ? JSON.parse(saved) : initialStages;
    } catch {
      return initialStages;
    }
  });
  const [query, setQuery] = useState("");
  const [typeFilter, setTypeFilter] = useState("Alle");
  const [selectedStageId, setSelectedStageId] = useState(1);
  const [darkMode, setDarkMode] = useState(() => localStorage.getItem("tdf2026DarkMode") !== "false");
  const [jsonText, setJsonText] = useState(JSON.stringify(stages, null, 2));
  const [jsonStatus, setJsonStatus] = useState("JSON is geladen uit lokale opslag of de starterdata.");

  useEffect(() => {
    localStorage.setItem("tdf2026StagesJson", JSON.stringify(stages));
    setJsonText(JSON.stringify(stages, null, 2));
  }, [stages]);

  useEffect(() => {
    localStorage.setItem("tdf2026DarkMode", String(darkMode));
  }, [darkMode]);

  const types = useMemo(() => ["Alle", ...Array.from(new Set(stages.map((stage) => stage.type)))], [stages]);

  const filteredStages = useMemo(() => {
    const normalized = query.trim().toLowerCase();
    return stages.filter((stage) => {
      const haystack = [
        stage.id,
        stage.date,
        stage.route,
        stage.type,
        stage.profile,
        stage.note,
        stage.confidence,
        ...(stage.top5 || []),
        ...(stage.contenders || [])
      ]
        .join(" ")
        .toLowerCase();
      const matchesQuery = !normalized || haystack.includes(normalized);
      const matchesType = typeFilter === "Alle" || stage.type === typeFilter;
      return matchesQuery && matchesType;
    });
  }, [query, typeFilter, stages]);

  const selectedStage = stages.find((stage) => stage.id === selectedStageId) || filteredStages[0] || stages[0];

  function applyJson() {
    try {
      const parsed = JSON.parse(jsonText);
      if (!Array.isArray(parsed)) throw new Error("JSON moet een array met etappes zijn.");
      const normalized = parsed.map((stage, index) => ({
        id: Number(stage.id || index + 1),
        date: stage.date || "2026-07-04",
        route: stage.route || "Onbekende route",
        distanceKm: Number(stage.distanceKm || 0),
        type: stage.type || "Onbekend",
        profile: stage.profile || "",
        top5: Array.isArray(stage.top5) ? stage.top5 : [],
        contenders: Array.isArray(stage.contenders) ? stage.contenders : [],
        note: stage.note || "",
        confidence: stage.confidence || "Onbekend"
      }));
      setStages(normalized);
      setSelectedStageId(normalized[0]?.id || 1);
      setJsonStatus("JSON succesvol toegepast en opgeslagen in localStorage.");
    } catch (error) {
      setJsonStatus(`JSON-fout: ${error.message}`);
    }
  }

  function resetData() {
    setStages(initialStages);
    setSelectedStageId(1);
    setJsonStatus("Starterdata teruggezet.");
  }

  const shellClass = darkMode
    ? "min-h-screen bg-slate-950 text-slate-100"
    : "min-h-screen bg-slate-100 text-slate-900";

  return (
    <div className={shellClass}>
      <div className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <header className="mb-8 overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-yellow-400 via-lime-500 to-cyan-500 p-[1px] shadow-2xl">
          <div className={classNames("rounded-[2rem] p-6 sm:p-8", darkMode ? "bg-slate-950/90" : "bg-white/90")}> 
            <div className="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
              <div>
                <p className="mb-2 text-sm font-semibold uppercase tracking-[0.25em] text-yellow-300">Tour de France 2026</p>
                <h1 className="text-3xl font-black tracking-tight sm:text-5xl">Ritwinnaar Voorspeller</h1>
                <p className={classNames("mt-3 max-w-3xl text-base", darkMode ? "text-slate-300" : "text-slate-600")}>Bekijk per etappe de kanshebbers voor ritwinst, filter op profiel en zoek op renner, plaats of type. De voorspellingen zijn bewerkbaar en worden als JSON lokaal opgeslagen.</p>
              </div>
              <button
                onClick={() => setDarkMode((value) => !value)}
                className={classNames("rounded-2xl px-5 py-3 text-sm font-bold shadow-lg transition hover:scale-[1.02]", darkMode ? "bg-white text-slate-950" : "bg-slate-950 text-white")}
              >
                {darkMode ? "☀️ Lightmode" : "🌙 Darkmode"}
              </button>
            </div>
            <div className="mt-6 grid gap-3 sm:grid-cols-4">
              <div className={classNames("rounded-2xl p-4", darkMode ? "bg-white/5" : "bg-slate-950/5")}>21 etappes</div>
              <div className={classNames("rounded-2xl p-4", darkMode ? "bg-white/5" : "bg-slate-950/5")}>7 vlak · 4 heuvel · 8 berg</div>
              <div className={classNames("rounded-2xl p-4", darkMode ? "bg-white/5" : "bg-slate-950/5")}>TTT + ITT</div>
              <div className={classNames("rounded-2xl p-4", darkMode ? "bg-white/5" : "bg-slate-950/5")}>JSON + localStorage</div>
            </div>
          </div>
        </header>

        <section className="mb-6 grid gap-4 lg:grid-cols-[1fr_220px_160px]">
          <input
            value={query}
            onChange={(event) => setQuery(event.target.value)}
            placeholder="Zoek op etappe, plaats, renner, team of profiel…"
            className={classNames("rounded-2xl border px-4 py-3 outline-none ring-0 transition focus:border-yellow-300", darkMode ? "border-white/10 bg-white/5 text-white placeholder:text-slate-500" : "border-slate-200 bg-white text-slate-900 placeholder:text-slate-400")}
          />
          <select
            value={typeFilter}
            onChange={(event) => setTypeFilter(event.target.value)}
            className={classNames("rounded-2xl border px-4 py-3 outline-none focus:border-yellow-300", darkMode ? "border-white/10 bg-white/5 text-white" : "border-slate-200 bg-white text-slate-900")}
          >
            {types.map((type) => <option key={type}>{type}</option>)}
          </select>
          <button onClick={() => downloadJson(stages)} className="rounded-2xl bg-yellow-300 px-4 py-3 font-black text-slate-950 shadow-lg transition hover:bg-yellow-200">Export JSON</button>
        </section>

        <main className="grid gap-6 lg:grid-cols-[390px_1fr]">
          <aside className="space-y-3">
            {filteredStages.map((stage) => (
              <button
                key={stage.id}
                onClick={() => setSelectedStageId(stage.id)}
                className={classNames(
                  "w-full rounded-3xl border p-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl",
                  selectedStage?.id === stage.id ? "border-yellow-300 ring-2 ring-yellow-300/30" : darkMode ? "border-white/10" : "border-slate-200",
                  darkMode ? "bg-white/5" : "bg-white"
                )}
              >
                <div className="mb-2 flex items-center justify-between gap-3">
                  <span className="text-sm font-black">Etappe {stage.id}</span>
                  <span className={classNames("rounded-full px-3 py-1 text-xs font-bold ring-1", typeStyles[stage.type] || "bg-slate-500/15 text-slate-300 ring-slate-400/30")}>{stage.type}</span>
                </div>
                <div className="font-bold">{stage.route}</div>
                <div className={classNames("mt-1 text-sm", darkMode ? "text-slate-400" : "text-slate-500")}>{stage.date} · {stage.distanceKm} km</div>
              </button>
            ))}
            {filteredStages.length === 0 && <div className="rounded-3xl border border-dashed border-slate-400 p-8 text-center">Geen etappes gevonden.</div>}
          </aside>

          <section className={classNames("rounded-[2rem] border p-5 shadow-2xl sm:p-7", darkMode ? "border-white/10 bg-white/5" : "border-slate-200 bg-white")}> 
            {selectedStage && (
              <>
                <div className="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <div className="mb-2 text-sm font-black uppercase tracking-[0.2em] text-yellow-300">Etappe {selectedStage.id}</div>
                    <h2 className="text-3xl font-black">{selectedStage.route}</h2>
                    <p className={classNames("mt-2", darkMode ? "text-slate-300" : "text-slate-600")}>{selectedStage.profile}</p>
                  </div>
                  <span className={classNames("w-fit rounded-full px-4 py-2 text-sm font-bold ring-1", typeStyles[selectedStage.type] || "bg-slate-500/15 text-slate-300 ring-slate-400/30")}>{selectedStage.type}</span>
                </div>

                <div className="grid gap-5 xl:grid-cols-2">
                  <div className={classNames("rounded-3xl p-5", darkMode ? "bg-slate-950/70" : "bg-slate-100")}> 
                    <h3 className="mb-4 text-xl font-black">Top 5 kanshebbers ritwinst</h3>
                    <ol className="space-y-3">
                      {selectedStage.top5.map((name, index) => (
                        <li key={name} className={classNames("flex items-center gap-3 rounded-2xl p-3", darkMode ? "bg-white/5" : "bg-white")}> 
                          <span className="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-yellow-300 font-black text-slate-950">{index + 1}</span>
                          <span className="font-bold">{name}</span>
                        </li>
                      ))}
                    </ol>
                  </div>

                  <div className={classNames("rounded-3xl p-5", darkMode ? "bg-slate-950/70" : "bg-slate-100")}> 
                    <h3 className="mb-4 text-xl font-black">Extra outsiders</h3>
                    <div className="flex flex-wrap gap-2">
                      {selectedStage.contenders.map((name) => (
                        <span key={name} className={classNames("rounded-full px-4 py-2 text-sm font-bold", darkMode ? "bg-white/10 text-slate-200" : "bg-white text-slate-700")}>{name}</span>
                      ))}
                    </div>
                    <div className={classNames("mt-5 rounded-2xl p-4 text-sm", darkMode ? "bg-white/5 text-slate-300" : "bg-white text-slate-600")}> 
                      <strong>Notitie:</strong> {selectedStage.note}
                    </div>
                    <div className="mt-3 text-sm font-bold text-yellow-300">Voorspelzekerheid: {selectedStage.confidence}</div>
                  </div>
                </div>
              </>
            )}
          </section>
        </main>

        <section className={classNames("mt-6 rounded-[2rem] border p-5 shadow-xl", darkMode ? "border-white/10 bg-white/5" : "border-slate-200 bg-white")}> 
          <div className="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 className="text-2xl font-black">JSON dataopslag</h2>
              <p className={classNames("text-sm", darkMode ? "text-slate-400" : "text-slate-500")}>Pas de data aan, klik op toepassen en de app slaat dit direct op in localStorage.</p>
            </div>
            <div className="flex gap-2">
              <button onClick={applyJson} className="rounded-2xl bg-lime-300 px-4 py-2 font-black text-slate-950">Toepassen</button>
              <button onClick={resetData} className={classNames("rounded-2xl px-4 py-2 font-black", darkMode ? "bg-white/10 text-white" : "bg-slate-200 text-slate-900")}>Reset</button>
            </div>
          </div>
          <textarea
            value={jsonText}
            onChange={(event) => setJsonText(event.target.value)}
            spellCheck="false"
            className={classNames("h-80 w-full rounded-2xl border p-4 font-mono text-xs outline-none focus:border-yellow-300", darkMode ? "border-white/10 bg-slate-950 text-lime-100" : "border-slate-200 bg-slate-50 text-slate-900")}
          />
          <p className={classNames("mt-3 text-sm", jsonStatus.startsWith("JSON-fout") ? "text-rose-400" : "text-lime-400")}>{jsonStatus}</p>
        </section>
      </div>
    </div>
  );
}
